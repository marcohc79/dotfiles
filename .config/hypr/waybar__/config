{
    "height": 50, 
    "layer": "top",
    "position": "top",
    /* "output": "eDP-1", */
    "spacing": 7,
    "modules-left": ["custom/launcher", "cpu", "temperature", "backlight", "custom/dunst"],
    "modules-center": ["wlr/workspaces"],
    "modules-right": ["pulseaudio", "network", "battery", "clock", "custom/powermenu"],

    "wlr/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "persistent_workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": [],
            "7": [],
            "8": [],
            "9": [],
        }
    },
    
    "custom/launcher": {
        "interval": "once",
        "format": "яМГ ",
        "on-click": "$HOME/.config/hypr/scripts/menu",
        "tooltip": false
      },

    "cpu": {
      "interval": 10,
      "format": "яЛЫ  {usage}%",
      "max-length": 10
    },

    "temperature": {
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
	"input-filename": "temp1_input",
	"format": "яЛЗ {temperatureC}┬░C",
	"on-click": "psensor"
    },

    "backlight": {
        "device": "nvidia_0",
	"max-length": "4",
        "format": "{icon}  {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-click": "",
        "on-scroll-up": "brightnessctl set 10%-",
        "on-scroll-down": "brightnessctl set +10%"
    },

    /* "custom/dunst": { */
    /*     "exec": "~/.config/waybar/scripts/dunst.sh", */
    /*     "on-click": "dunstctl set-paused toggle", */
    /*     "restart-interval": 1, */
    /*     "tooltip": false */
    /* }, */

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon}яКФ {volume}% {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "якА",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click-right": "pavucontrol",
	    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "network": {
        "format-wifi": "яки  {signalStrength}%",
        "format-ethernet": "яЫ┐ wired",
        "format-disconnected": "якй ",
        "on-click": "sh ~/.config/hypr/scripts/wifimenu.sh"
    },

    "battery": {
      "bat": "BAT0",
      "adapter": "ADP0",
      "interval": 60,
      "states": {
          "warning": 30,
          "critical": 15
      },
      "max-length": 20,
      "format": "{icon}  {capacity}%",
      "format-warning": "{icon}  {capacity}%",
      "format-critical": "{icon}  {capacity}%",
      "format-charging": "яЗж  {capacity}%",
      "format-plugged": "яЗж  {capacity}%",
      "format-alt": "{icon}  {time}",
      "format-full": "яЗж  {capacity}%",
      "format-icons": ["яЙД ", "яЙГ ", "яЙВ ", "яЙБ ", "яЙА "]
    },

    "clock": {
        "format-alt": "<span>яБ│ </span> {:%a %b %d}",
        "format": "<span>яАЧ </span> {:%I:%M %p}"
    },

    "custom/powermenu": {
        "format": "яАС",
        "on-click": "$HOME/.config/hypr/scripts/wlogout",
        "tooltip": false
    }
}
